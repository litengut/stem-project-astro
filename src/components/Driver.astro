---
import type { DriverStanding } from "../fetch"
import type { Driver as OpenF1Driver } from "openf1-client/dist/types"
import Avatar from "./Avatar.astro"
import PositionBadge from "./PositionBadge.astro"

interface Props {
  standing: DriverStanding & {
    driver?: OpenF1Driver
  }
}

const { standing } = Astro.props

const driverName =
  standing.driver?.full_name ??
  [standing.driver?.first_name, standing.driver?.last_name]
    .filter(Boolean)
    .join(" ") ??
  standing.driver?.name_acronym ??
  `#${standing.driver_number}`
---

<div
  class={`group relative grid grid-cols-[50px_1fr_auto] items-center gap-2 rounded-lg px-4 py-3 transit
ion-all duration-300 hover:bg-secondary/80 md:grid-cols-[50px_60px_1fr_120px_80px_80px_200px] md:gap-4 md:px-6 ${
    /*isTop3 */ true ? "border border-border bg-secondary/50" : ""
  }`}
>
  {/* Position */}
  <div class="flex h-8 w-8 items-center justify-center rounded-full bg-muted">
    <PositionBadge position={standing.position_current} />
  </div>

  {/* Number - hidden on mobile */}
  <div class="hidden items-center justify-center md:flex">
    <span
      class="font-display text-lg font-bold opacity-30"
      style={{ color: standing.driver?.team_colour }}
    >
      {standing.driver?.driver_number}
    </span>
  </div>

  {/* Name & Team */}
  <div class="flex min-w-0 flex-col">
    <div class="flex items-center gap-2">
      <span class="text-sm">{standing.driver?.nationality}</span>
      <span class="font-body truncate font-semibold text-foreground">
        {driverName}
      </span>
    </div>
    <div class="flex items-center gap-2">
      <div
        class="h-2 w-2 shrink-0 rounded-full"
        style={{ backgroundColor: standing.driver?.team_colour }}
      >
      </div>
      <span class="truncate text-xs text-muted-foreground"
        >{standing.driver?.team_name}</span
      >
    </div>
  </div>

  {/* Team */}
  <div class=""></div>

  {/* Wins */}
  <div class="flex flex-col items-center">
    <span class="font-display text-sm font-bold text-foreground">
      <!-- {standing.driver?.win ?? 0} -->
    </span>
    <span class="text-[10px] tracking-wider text-muted-foreground uppercase"
      >Wins</span
    >
  </div>

  {/* Podiums */}
  <div class="flex flex-col items-center">
    <span class="font-display text-sm font-bold text-foreground">
      <!-- {standing.driver?.podiums ?? 0} -->
    </span>
    <span class="text-[10px] tracking-wider text-muted-foreground uppercase"
      >Pods</span
    >
  </div>

  {/* Points bar */}
  <div class="flex items-center gap-3">
    <div
      class="relative block h-2 flex-1 overflow-hidden rounded-full bg-muted"
    >
      <!-- <div
        class="absolute inset-y-0 left-0 rounded-full transition-all duration-1000 ease-out"
        style={{
          width: `${barWidth}%`,
          backgroundColor: standing.driver?.team_colour,
          boxShadow: `0 0 10px ${standing.driver?.team_colour}66`,
        }}
      > -->
    </div>
  </div>
  <span class="font-display min-w-10 text-right text-sm font-bold text-primary">
    {standing.points_current}
  </span>
</div>

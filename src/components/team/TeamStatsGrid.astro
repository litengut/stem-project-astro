---
import type { TeamContent } from "@/lib/teams"
import StatsGrid from "../StatsGrid.astro"

type Props = {
  team: TeamContent
}

const { team } = Astro.props
const positionDelta = team.positionStart - team.position
const pointsDelta = team.points - team.pointsStart
const positionDeltaLabel =
  positionDelta > 0 ? `+${positionDelta}` : `${positionDelta}`
const pointsDeltaLabel = pointsDelta > 0 ? `+${pointsDelta}` : `${pointsDelta}`

const stats = [
  { label: "Season Position", value: `P${team.position}` },
  { label: "Season Points", value: `${team.points}` },
  { label: "Position Change", value: positionDeltaLabel },
  { label: "Points Change", value: pointsDeltaLabel },
  { label: "Drivers", value: `${team.roster.length}` },
  { label: "First Team Entry", value: "1997" },
]
---

<StatsGrid title="2026 Season" rows={stats} />

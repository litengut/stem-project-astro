---
import type { TeamContent } from "@/lib/teams"
import TeamStatsGrid from "@/components/team/TeamStatsGrid.astro"
import TeamSummaryCard from "@/components/team/TeamSummaryCard.astro"

type Props = {
  team: TeamContent
}

const { team } = Astro.props
---

<section class="mx-auto max-w-6xl px-4 py-8 md:px-8 md:py-10">
  <h2 class="text-4xl font-black tracking-tight">Statistics</h2>

  <div class="mt-6 grid grid-cols-[1.1fr_0.9fr] items-start gap-6">
    <TeamStatsGrid team={team} />
    <TeamSummaryCard />
  </div>
</section>

---
import type { TeamContent } from "@/lib/teams"

type Props = {
  team: TeamContent
}

const { team } = Astro.props
---

<section
  class="mx-auto grid max-w-6xl gap-6 px-4 pb-10 md:grid-cols-3 md:px-8 md:pb-12"
>
  <article class="rounded-xl border bg-card p-5 md:col-span-2">
    <h2 class="text-lg font-semibold">Team History</h2>
    <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
      {team.history}
    </p>
  </article>

  <article class="rounded-xl border bg-card p-5">
    <h2 class="text-lg font-semibold">Identity</h2>
    <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
      {team.identity}
    </p>
  </article>

  <article class="rounded-xl border bg-card p-5 md:col-span-2">
    <h2 class="text-lg font-semibold">Season Outlook</h2>
    <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
      {team.outlook}
    </p>
  </article>
</section>

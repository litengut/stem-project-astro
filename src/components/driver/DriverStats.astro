---
type DriverStatsData = {
  position: number
  points: number
  pointsGap: number
}

type Props = {
  driver: DriverStatsData
}

const { driver } = Astro.props
---

<section class="mx-auto max-w-6xl px-4 py-10">
  <div class="grid grid-cols-3 gap-4">
    <article class="rounded-2xl border border-border bg-card p-5">
      <p class="text-xs text-muted-foreground uppercase">Position</p>
      <p class="mt-2 text-4xl font-black">P{driver.position}</p>
    </article>
    <article class="rounded-2xl border border-border bg-card p-5">
      <p class="text-xs text-muted-foreground uppercase">Points</p>
      <p class="font-blackt mt-2 text-4xl">{driver.points}</p>
    </article>
    <article class="rounded-2xl border border-border bg-card p-5">
      <p class="text-xs text-muted-foreground uppercase">Gap to Leader</p>
      <p class="mt-2 text-4xl font-black">{driver.pointsGap}</p>
    </article>
  </div>
</section>

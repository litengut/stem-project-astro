---
type DriverHeroData = {
  firstName: string
  lastName: string
  fullName: string
  teamName: string
  teamColor: string
  driverNumber: number
  portraitUrl: string
}

type Props = {
  driver: DriverHeroData
}

const { driver } = Astro.props
---

{/* I change a little bit of the gradiant but I didn't write it my */}
<section
  class="relative h-112 overflow-hidden rounded-b-[2.25rem] border-b border-white/10 text-white"
  style={`background: linear-gradient(130deg, #0b0d12 0%, color-mix(in srgb, ${driver.teamColor} 30%, #0b0d12 70%) 42%, #0a0a0a 100%);`}
>
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_22%_20%,rgba(255,255,255,0.12),transparent_45%)]"
  >
  </div>
  <div
    class="relative mx-auto grid h-full max-w-6xl grid-cols-[1fr_0.9fr] items-end gap-6 px-4 py-16"
  >
    <div class="self-start pt-8">
      <p class="text-xs font-semibold text-white/70 uppercase">
        Driver Profile
      </p>
      <h1 class="mt-3 max-w-[8ch] text-6xl font-black text-balance">
        {driver.firstName}
        <br />
        {driver.lastName}
      </h1>
      <div class="mt-5 flex flex-wrap items-center gap-3">
        <span
          class="rounded-md bg-white px-3 py-1 text-xs font-semibold text-black uppercase"
        >
          #{driver.driverNumber}
        </span>
        <span
          class="rounded-md border border-white/30 px-3 py-1 text-xs font-medium uppercase"
        >
          {driver.teamName}
        </span>
      </div>
    </div>

    <div class="relative flex justify-end">
      <div
        class="absolute inset-x-6 bottom-2 h-24 rounded-full bg-[color:var(--driver-team-color)]/45 blur-3xl"
      >
      </div>
      <div class="relative z-10 h-[24rem] w-[22rem] translate-y-5">
        <img
          src={driver.portraitUrl}
          alt={driver.fullName}
          class="relative scale-115 object-cover [object-position:center_-10%]"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
